    "schema": "public",
    "name": "active_customers",
    "owner": "pgcarter",
    "definition": "SELECT c.id,\n    c.email,\n    o.name AS org_name\n   FROM customer c\n     JOIN org o ON o.id = c.org_id\n  WHERE c.status = 'active'::text;",
    "materialized": false,
    "comment": "Active customers with their organisation name",
